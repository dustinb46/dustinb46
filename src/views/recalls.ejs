<% const title = 'Recalls'; %>
<%- include('_header', { title, disclaimer }) %>

<h1>Recalls</h1>
<form class="filters" method="get">
  <label>Class
    <select name="class">
      <option value="">any</option>
      <% for (const c of ['Class I','Class II','Class III']) { %>
        <option value="<%= c %>" <%= cls === c ? 'selected' : '' %>><%= c %></option>
      <% } %>
    </select>
  </label>
  <label>Matched
    <select name="matched">
      <option value=""    <%= !matched ? 'selected' : '' %>>any</option>
      <option value="yes" <%= matched === 'yes' ? 'selected' : '' %>>matched to plant</option>
      <option value="no"  <%= matched === 'no'  ? 'selected' : '' %>>unmatched</option>
    </select>
  </label>
  <button type="submit">Filter</button>
</form>

<% if (!recalls.length) { %>
  <p class="empty">No recalls match these filters. If the table is empty entirely, run <code>npm run recalls:sync</code>.</p>
<% } else { %>
  <table>
    <thead><tr><th>Date</th><th>Firm</th><th>Plant</th><th>Class</th><th>Reason</th><th>Status</th></tr></thead>
    <tbody>
      <% for (const r of recalls) { %>
        <tr>
          <td><%= r.recall_date || r.report_date || '' %></td>
          <td><%= r.firm_name || '' %><br><small class="muted"><%= [r.firm_city, r.firm_state].filter(Boolean).join(', ') %></small></td>
          <td>
            <% if (r.plant_id) { %>
              <a href="/plant/<%= r.plant_code %>"><%= r.plant_name %></a>
              <br><small class="conf conf-<%= (r.match_confidence || 0) >= 0.7 ? 'high' : 'low' %>">
                <%= r.match_method %> · <%= Math.round((r.match_confidence || 0) * 100) %>%
              </small>
            <% } else { %>
              <span class="muted">unmatched</span>
            <% } %>
          </td>
          <td><%= r.classification || '' %></td>
          <td><%= (r.reason || '').slice(0, 200) %></td>
          <td><%= r.status || '' %></td>
        </tr>
      <% } %>
    </tbody>
  </table>
<% } %>

<%- include('_footer') %>
