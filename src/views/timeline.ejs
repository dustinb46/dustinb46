<% const title = 'Dairy plant news & recalls'; %>
<%- include('_header', { title, disclaimer }) %>

<h1>Dairy plant news &amp; recalls</h1>
<p class="lede">
  A running feed of FDA enforcement records for U.S. dairy plants — grouped by recall event, linked to the plant where we can identify it. Plant news from press releases and trade reporting will land here too as we wire those sources in.
</p>

<details class="filter-bar"<%= Object.keys(filters || {}).length ? ' open' : '' %>>
  <summary>Filter <span class="muted">(class, state, date, firm, match status)</span></summary>
  <form class="filters" method="get">
    <label>Class
      <select name="class">
        <option value="">any</option>
        <% for (const c of ['Class I','Class II','Class III']) { %>
          <option value="<%= c %>" <%= filters.class === c ? 'selected' : '' %>><%= c %></option>
        <% } %>
      </select>
    </label>
    <label>State <span class="muted">(firm)</span>
      <input type="text" name="state" maxlength="2" value="<%= filters.state || '' %>" placeholder="e.g. CA" />
    </label>
    <label>From
      <input type="date" name="from" value="<%= filters.from || '' %>" />
    </label>
    <label>To
      <input type="date" name="to" value="<%= filters.to || '' %>" />
    </label>
    <label>Firm contains
      <input type="text" name="firm" value="<%= filters.firm || '' %>" />
    </label>
    <label>Match status
      <select name="matched">
        <option value=""    <%= !filters.matched ? 'selected' : '' %>>any</option>
        <option value="yes" <%= filters.matched === 'yes' ? 'selected' : '' %>>matched to plant</option>
        <option value="no"  <%= filters.matched === 'no'  ? 'selected' : '' %>>unmatched</option>
      </select>
    </label>
    <button type="submit">Apply</button>
    <% if (Object.keys(filters || {}).length) { %>
      <a class="clear-filters" href="/timeline">Clear</a>
    <% } %>
  </form>
</details>

<section class="feed-stats">
  <span><strong><%= total.toLocaleString() %></strong> recall event<%= total === 1 ? '' : 's' %></span>
  <span class="sep">·</span>
  <span><strong><%= matched.toLocaleString() %></strong> matched to plant</span>
  <span class="sep">·</span>
  <span><strong><%= total ? Math.round(100 * matched / total) : 0 %>%</strong> match rate</span>
  <span class="sep">·</span>
  <a href="/api/recalls.csv?<%= new URLSearchParams(filters).toString() %>">CSV</a>
  <span class="sep">·</span>
  <a href="/api/recalls.json?<%= new URLSearchParams(filters).toString() %>">JSON</a>
</section>

<%
  // Group feed items by month for the date headings.
  function monthLabel(iso) {
    if (!iso) return 'Undated';
    const d = new Date(iso + 'T00:00:00Z');
    return d.toLocaleDateString('en-US', { month: 'long', year: 'numeric', timeZone: 'UTC' });
  }
  function dayLabel(iso) {
    if (!iso) return '';
    const d = new Date(iso + 'T00:00:00Z');
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
  }
  function classTag(c) {
    if (!c) return '';
    if (/I\b/.test(c) && !/II/.test(c)) return 'class-i';
    if (/II\b/.test(c) && !/III/.test(c)) return 'class-ii';
    if (/III/.test(c)) return 'class-iii';
    return '';
  }
%>

<% if (!recent.length) { %>
  <section class="feed">
    <p class="empty">Nothing matches these filters. Try clearing them, or widening the date range.</p>
  </section>
<% } else { %>
  <section class="feed" aria-label="Recall and news feed">
    <% let lastMonth = null; %>
    <% for (const r of recent) { %>
      <% const month = monthLabel(r.recall_date); %>
      <% if (month !== lastMonth) { lastMonth = month; %>
        <h2 class="feed-month"><%= month %></h2>
      <% } %>
      <article class="feed-item">
        <header class="feed-item-head">
          <span class="feed-date" title="<%= r.recall_date || '' %>"><%= dayLabel(r.recall_date) %></span>
          <% if (r.classification) { %>
            <span class="class-tag <%= classTag(r.classification) %>"><%= r.classification %></span>
          <% } %>
          <span class="feed-kind">Recall</span>
        </header>
        <h3 class="feed-headline">
          <% if (r.plant_id) { %>
            <a href="/plant/<%= r.plant_code %>"><%= r.plant_name %></a>
          <% } else { %>
            <%= r.firm_name || 'Unknown firm' %>
          <% } %>
        </h3>
        <p class="feed-meta">
          <% if (r.plant_id && r.firm_name && r.firm_name !== r.plant_name) { %>
            <span class="muted">Recalled by</span> <%= r.firm_name %>
          <% } else if (!r.plant_id) { %>
            <span class="muted">Plant not yet identified</span>
          <% } %>
          <% if (r.product_count > 1) { %>
            <span class="sep">·</span> <strong><%= r.product_count %></strong> products affected
          <% } %>
        </p>
        <% if (r.reason) { %>
          <p class="feed-reason"><%= r.reason.length > 280 ? r.reason.slice(0, 280) + '…' : r.reason %></p>
        <% } %>
      </article>
    <% } %>
  </section>
<% } %>

<aside class="feed-aside">
  <section>
    <h3>By class <span class="muted">(matching filters)</span></h3>
    <ul class="class-breakdown">
      <% for (const c of byClass) { %>
        <li><span class="class-tag <%= classTag(c.classification) %>"><%= c.classification %></span> <%= c.n.toLocaleString() %></li>
      <% } %>
    </ul>
  </section>
  <% if (topFirms.length) { %>
    <section>
      <h3>Most active firms</h3>
      <ul class="top-firms">
        <% for (const f of topFirms.slice(0, 10)) { %>
          <li>
            <a href="/timeline?firm=<%= encodeURIComponent(f.firm_name) %>"><%= f.firm_name %></a>
            <span class="muted"><%= f.n %><% if (f.c1) { %> · <%= f.c1 %> Class I<% } %></span>
          </li>
        <% } %>
      </ul>
    </section>
  <% } %>
</aside>

<%- include('_footer') %>
