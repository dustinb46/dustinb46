<% const title = 'Recall timeline'; %>
<%- include('_header', { title, disclaimer }) %>

<h1>Recall timeline</h1>
<p class="lede">
  Dairy recalls over time, drawn from the FDA Food Enforcement database
  and (where possible) matched to specific manufacturing plants. Use the
  filters to narrow by class, state, time range, or recalling firm.
</p>

<form class="filters" method="get">
  <label>Class
    <select name="class">
      <option value="">any</option>
      <% for (const c of ['Class I','Class II','Class III']) { %>
        <option value="<%= c %>" <%= filters.class === c ? 'selected' : '' %>><%= c %></option>
      <% } %>
    </select>
  </label>
  <label>State (firm)
    <input type="text" name="state" maxlength="2" value="<%= filters.state || '' %>" />
  </label>
  <label>From
    <input type="date" name="from" value="<%= filters.from || '' %>" />
  </label>
  <label>To
    <input type="date" name="to" value="<%= filters.to || '' %>" />
  </label>
  <label>Firm contains
    <input type="text" name="firm" value="<%= filters.firm || '' %>" />
  </label>
  <label>Matched
    <select name="matched">
      <option value=""    <%= !filters.matched ? 'selected' : '' %>>any</option>
      <option value="yes" <%= filters.matched === 'yes' ? 'selected' : '' %>>matched</option>
      <option value="no"  <%= filters.matched === 'no'  ? 'selected' : '' %>>unmatched</option>
    </select>
  </label>
  <button type="submit">Apply</button>
</form>

<section class="stats">
  <div><strong><%= total.toLocaleString() %></strong><span>recall events</span></div>
  <div><strong><%= matched.toLocaleString() %></strong><span>matched to plant</span></div>
  <div><strong><%= total ? Math.round(100 * matched / total) : 0 %>%</strong><span>match rate</span></div>
</section>
<p class="note">Counts are distinct recall events. A single recall often covers many products; we group those together.</p>

<p class="export-row">
  <a href="/api/recalls.csv?<%= new URLSearchParams(filters).toString() %>">Download CSV</a>
  <span class="muted"> · </span>
  <a href="/api/recalls.json?<%= new URLSearchParams(filters).toString() %>">JSON</a>
</p>

<h2>Monthly volume</h2>
<% if (!monthly.length) { %>
  <p class="empty">No date-stamped recalls match these filters.</p>
<% } else {
  const maxN = Math.max(...monthly.map(m => m.n));
%>
  <table class="timeline-bars">
    <thead><tr><th>Month</th><th>Class I</th><th>Class II</th><th>Class III</th><th>Total</th><th></th></tr></thead>
    <tbody>
      <% for (const m of monthly) {
           const pct = Math.round(100 * m.n / maxN);
      %>
        <tr>
          <td><%= m.ym %></td>
          <td><%= m.c1 %></td>
          <td><%= m.c2 %></td>
          <td><%= m.c3 %></td>
          <td><strong><%= m.n %></strong></td>
          <td class="bar-cell"><span class="bar" style="width:<%= pct %>%"></span></td>
        </tr>
      <% } %>
    </tbody>
  </table>
<% } %>

<div class="two-col">
  <section>
    <h2>By class</h2>
    <table>
      <thead><tr><th>Class</th><th>Count</th></tr></thead>
      <tbody>
        <% for (const c of byClass) { %>
          <tr><td><%= c.classification %></td><td><%= c.n %></td></tr>
        <% } %>
      </tbody>
    </table>
  </section>

  <section>
    <h2>Most-recalled firms</h2>
    <% if (!topFirms.length) { %>
      <p class="empty">No firms yet.</p>
    <% } else { %>
      <table>
        <thead><tr><th>Firm</th><th>Total</th><th>Class I</th></tr></thead>
        <tbody>
          <% for (const f of topFirms) { %>
            <tr>
              <td><a href="/timeline?firm=<%= encodeURIComponent(f.firm_name) %>"><%= f.firm_name %></a></td>
              <td><%= f.n %></td>
              <td><%= f.c1 %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    <% } %>
  </section>
</div>

<h2>Latest 50 recall events</h2>
<% if (!recent.length) { %>
  <p class="empty">Nothing to show. Try widening the filters.</p>
<% } else { %>
  <table>
    <thead><tr><th>Date</th><th>Firm</th><th>Plant</th><th>Class</th><th>Products</th><th>Reason</th></tr></thead>
    <tbody>
      <% for (const r of recent) { %>
        <tr>
          <td><%= r.recall_date || '' %></td>
          <td><%= r.firm_name || '' %></td>
          <td>
            <% if (r.plant_id) { %>
              <a href="/plant/<%= r.plant_code %>"><%= r.plant_name %></a>
            <% } else { %>
              <span class="muted">unmatched</span>
            <% } %>
          </td>
          <td><%= r.classification || '' %></td>
          <td><%= r.product_count > 1 ? r.product_count + ' products' : '1' %></td>
          <td><%= (r.reason || '').slice(0, 160) %></td>
        </tr>
      <% } %>
    </tbody>
  </table>
<% } %>

<%- include('_footer') %>
