<% const title = `${plant.plant_code} — ${plant.name}`; %>
<%- include('_header', { title, disclaimer }) %>

<h1><%= plant.name %></h1>
<p class="code-line">
  <span class="badge"><%= plant.plant_code %></span>
  <% if (plant.category) { %><span class="muted"><%= plant.category %></span><% } %>
  <% if (via && via !== 'ims') { %>
    <span class="muted">(matched via <%= via %> alias)</span>
  <% } %>
</p>

<dl class="meta">
  <% if (plant.parent_company) { %><dt>Parent</dt><dd><%= plant.parent_company %></dd><% } %>
  <% if (plant.address || plant.city || plant.state) { %>
    <dt>Address</dt><dd>
      <%= [plant.address, plant.city, plant.state].filter(Boolean).join(', ') %>
    </dd>
  <% } %>
  <% if (plant.fmmo_pool) { %><dt>FMMO pool</dt><dd><%= plant.fmmo_pool %></dd><% } %>
  <% if (plant.ims_rating) { %><dt>IMS rating</dt><dd><%= plant.ims_rating %></dd><% } %>
  <% if (plant.source) { %><dt>Source</dt><dd><%= plant.source %></dd><% } %>
  <% if (plant.last_verified) { %><dt>Last verified</dt><dd><%= plant.last_verified %></dd><% } %>
</dl>

<%
  const mapQuery = [plant.name, plant.address, plant.city, plant.state]
    .filter(Boolean).join(' ');
  const mapsUrl = 'https://www.google.com/maps/search/?api=1&query='
    + encodeURIComponent(mapQuery);
  const hasGeo = plant.lat != null && plant.lon != null;
%>
<% if (hasGeo) { %>
  <div id="plant-mini-map" class="plant-mini-map"
       data-lat="<%= plant.lat %>" data-lon="<%= plant.lon %>"
       data-label="<%= (plant.name || '').replace(/"/g, '&quot;') %>"></div>
<% } %>
<p class="map-link">
  <a href="<%= mapsUrl %>" target="_blank" rel="noopener noreferrer">
    Open in Google Maps &rarr;
  </a>
  <span class="muted">Satellite view centers on the city; zoom to find the facility. Open in Google Maps for Street View.</span>
</p>

<% if (hasGeo) { %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
          integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <script>
    (function () {
      var el = document.getElementById('plant-mini-map');
      if (!el || typeof L === 'undefined') return;
      var lat = parseFloat(el.dataset.lat), lon = parseFloat(el.dataset.lon);

      function build() {
        // Moderate zoom: coords are city centroids, so this shows the
        // town and surroundings honestly. Zoom in further to hunt the
        // building; tighten the default once we have street-level coords.
        var map = L.map(el, { scrollWheelZoom: false }).setView([lat, lon], 13);

        // Free satellite imagery from Esri — no API key, no billing.
        var satellite = L.tileLayer(
          'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
          { maxZoom: 18, attribution: 'Imagery &copy; Esri' }
        );
        // Street fallback so the toggle has a non-aerial option.
        var street = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
          { maxZoom: 19, attribution: '&copy; OpenStreetMap contributors' });

        satellite.addTo(map);
        L.control.layers({ 'Satellite': satellite, 'Street': street }, null,
          { collapsed: false }).addTo(map);
        L.marker([lat, lon]).addTo(map).bindPopup(el.dataset.label);
      }

      // Lazy-load: the satellite tiles are the heaviest thing on the page,
      // so only build the map once it scrolls into view.
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries, obs) {
          if (entries[0].isIntersecting) { build(); obs.disconnect(); }
        }, { rootMargin: '200px' });
        io.observe(el);
      } else {
        build();
      }
    })();
  </script>
<% } %>

<% if (typeof related !== 'undefined' && related.length) { %>
  <section class="related-site">
    <h2>Also at this site</h2>
    <p class="muted">
      Other plant codes registered at the same operator in <%= plant.city %>, <%= plant.state %>.
      Often the main plant plus a bulk tank unit, receiving line, or a separate USDA listing for the same building.
    </p>
    <ul class="related-list">
      <% for (const r of related) { %>
        <li>
          <a href="/plant/<%= r.plant_code %>"><code><%= r.plant_code %></code> <%= r.name %></a>
          <% if (r.category) { %><span class="muted"> · <%= r.category %></span><% } %>
          <% if (r.source) { %><span class="conf conf-<%= r.source === 'IMS' ? 'high' : 'medium' %>"><%= r.source %></span><% } %>
        </li>
      <% } %>
    </ul>
  </section>
<% } %>

<% if (aliases && aliases.length > 1) { %>
  <h2>Code aliases</h2>
  <ul class="aliases">
    <% for (const a of aliases) { %>
      <li><code><%= a.code %></code> <span class="muted"><%= a.code_system %></span></li>
    <% } %>
  </ul>
<% } %>

<h2>Brands made here</h2>
<% if (!brands.length) { %>
  <p class="empty">No brand mappings recorded for this plant.</p>
<% } else { %>
  <table>
    <thead><tr><th>Brand</th><th>Category</th><th>Region</th><th>Confidence</th><th>Source</th><th>Verified</th></tr></thead>
    <tbody>
      <% for (const b of brands) { %>
        <tr>
          <td><a href="/brand/<%= b.brand_id %>"><%= b.brand_name %></a></td>
          <td><%= b.product_category || '' %></td>
          <td><%= b.region || '' %></td>
          <td><span class="conf conf-<%= b.confidence %>"><%= b.confidence %></span></td>
          <td><%= b.source %></td>
          <td><%= b.last_verified || '' %></td>
        </tr>
      <% } %>
    </tbody>
  </table>
  <p class="note">Each mapping links to where we sourced it. Hover any badge to see how confident we are.</p>
<% } %>

<h2>Inspection &amp; recall history</h2>
<% if (!recalls.length) { %>
  <p class="empty">No public FDA enforcement records linked to this plant.</p>
<% } else { %>
  <p class="note">FDA recall records that match this plant. <a href="/timeline">See the full recall timeline →</a></p>
  <table>
    <thead><tr><th>Date</th><th>Class</th><th>Reason</th><th>Status</th><th>How we matched</th></tr></thead>
    <tbody>
      <% for (const r of recalls) { %>
        <tr>
          <td><%= r.recall_date || r.report_date || '' %></td>
          <td><%= r.classification || '' %></td>
          <td><%= (r.reason || '').slice(0, 200) %></td>
          <td><%= r.status || '' %></td>
          <td>
            <span class="conf conf-<%= (r.match_confidence || 0) >= 0.7 ? 'high' : 'low' %>" title="<%= r.match_method %>">
              <%= Math.round((r.match_confidence || 0) * 100) %>% · <%= r.match_method %>
            </span>
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
<% } %>

<%- include('_footer') %>
