<% const title = 'Look up any dairy plant'; %>
<%- include('_header', { title, disclaimer }) %>

<section class="hero"<% if (typeof heroPhoto !== 'undefined' && heroPhoto) { %> style="--hero-photo: url('<%= heroPhoto %>')"<% } %>>
  <div class="hero-overlay"></div>
  <div class="hero-inner">
    <p class="eyebrow">The reference atlas for U.S. dairy plants</p>
    <h1>Every U.S. dairy plant. Every operator. Every brand.</h1>
    <p class="hero-lede">
      A reference atlas for the U.S. dairy industry. Search by plant code,
      operator, brand, or city to see who runs which plant, what they make,
      and what's been recalled or announced lately.
    </p>

    <form class="hero-search" action="/search" method="get" role="search">
      <input type="search" name="q" autofocus
             placeholder='Try a code like "55-372", or "Cabot", or "fairlife"' />
      <button type="submit">Look it up</button>
    </form>

    <p class="hero-hints">
      <span>Quick examples:</span>
      <a href="/search?q=cabot">Cabot</a>
      <a href="/search?q=fairlife">fairlife</a>
      <a href="/search?q=Hilmar">Hilmar Cheese</a>
      <a href="/plant/55-372">55-372</a>
      <a href="/plant/06-71">06-71</a>
    </p>
  </div>
</section>

<section class="stats-row">
  <div><strong><%= stats.plants.toLocaleString() %></strong><span>plants mapped</span></div>
  <div><strong><%= stats.brands.toLocaleString() %></strong><span>brands traced</span></div>
  <div><strong><%= stats.mappings.toLocaleString() %></strong><span>brand-to-plant links</span></div>
  <div><strong>50</strong><span>states covered</span></div>
</section>

<section class="map-section">
  <h2>Every plant we know about</h2>
  <p class="muted">Click a dot to open the plant.</p>
  <div id="plant-map" class="plant-map" aria-label="Map of U.S. dairy plants"></div>
</section>

<section class="explainer">
  <h2>How to read a plant code</h2>
  <div class="explainer-grid">
    <div>
      <h3>Find it on the package</h3>
      <p>
        Look for a stamp like <code>55-23</code> on the carton, lid, or
        side of the package. It's usually near the date code.
      </p>
    </div>
    <div>
      <h3>What the numbers mean</h3>
      <p>
        The first part is the state (FIPS code). The second is the
        plant's number within that state. Together they identify one
        specific facility — even if the carton says a different brand.
      </p>
    </div>
    <div>
      <h3>Why brands differ from makers</h3>
      <p>
        Many dairy products are co-packed: a single plant can produce
        cottage cheese for four different brands at once. The plant
        code is the only honest way to know which facility made yours.
      </p>
    </div>
  </div>
</section>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<link rel="stylesheet"
      href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
<link rel="stylesheet"
      href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
<script>
  (async function () {
    var el = document.getElementById('plant-map');
    if (!el || typeof L === 'undefined') return;
    var map = L.map(el, { scrollWheelZoom: false }).setView([39.5, -98.35], 4);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors',
      maxZoom: 12,
    }).addTo(map);

    try {
      var res = await fetch('/api/plants/geo.json');
      var data = await res.json();
      var cluster = L.markerClusterGroup({ chunkedLoading: true });
      function esc(s) { return String(s == null ? '' : s).replace(/[<>&"]/g, function (c) { return ({ '<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;' })[c]; }); }
      data.plants.forEach(function (p) {
        var m = L.marker([p.lat, p.lon]);
        var loc = esc((p.city || '') + ', ' + (p.state || ''));
        // Facility groups carry one or more codes; render them as a list.
        var codes = p.codes || [{ plant_code: p.plant_code, name: p.name, category: p.category }];
        var head = '<strong>' + esc(p.name) + '</strong><br><span style="color:#6b6258">' + loc + '</span>';
        var body = '<ul style="margin:0.4rem 0 0;padding:0 0 0 1rem;">' +
          codes.map(function (c) {
            var cat = c.category ? ' <em style="color:#6b6258">· ' + esc(c.category) + '</em>' : '';
            return '<li><a href="/plant/' + encodeURIComponent(c.plant_code) + '"><code>' +
              esc(c.plant_code) + '</code></a>' + cat + '</li>';
          }).join('') +
          '</ul>';
        var label = codes.length > 1 ? ' <em style="color:#6b6258">(' + codes.length + ' codes)</em>' : '';
        m.bindPopup(head + label + body);
        cluster.addLayer(m);
      });
      map.addLayer(cluster);
      if (data.plants.length === 0) {
        el.insertAdjacentHTML('beforeend',
          '<div class="map-empty">No plants geocoded yet. Run <code>geocode</code> on the admin endpoint.</div>');
      }
    } catch (e) {
      el.insertAdjacentHTML('beforeend',
        '<div class="map-empty">Map couldn\'t load: ' + (e && e.message || e) + '</div>');
    }
  })();
</script>

<%- include('_footer') %>
