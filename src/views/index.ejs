<% const title = 'Home'; %>
<%- include('_header', { title, disclaimer }) %>

<h1>Who actually made your dairy?</h1>
<p class="lede">
  Every dairy package carries a plant code identifying the actual processor.
  This site maps those codes to plants, brands, and recall history.
</p>

<%- include('_search-form', { q: '', state: '', parent: '' }) %>

<section class="stats">
  <div><strong><%= stats.plants.toLocaleString() %></strong><span>plants</span></div>
  <div><strong><%= stats.brands.toLocaleString() %></strong><span>brands</span></div>
  <div><strong><%= stats.mappings.toLocaleString() %></strong><span>brand mappings</span></div>
  <div><strong><%= stats.recalls.toLocaleString() %></strong><span>recalls tracked</span></div>
</section>

<h2>Recent recalls</h2>
<% if (!recent.length) { %>
  <p class="empty">No recalls loaded yet. Run <code>npm run recalls:sync</code>.</p>
<% } else { %>
  <table>
    <thead><tr><th>Date</th><th>Firm</th><th>Plant match</th><th>Class</th><th>Reason</th></tr></thead>
    <tbody>
      <% for (const r of recent) { %>
        <tr>
          <td><%= r.recall_date || r.report_date || '' %></td>
          <td><%= r.firm_name || '' %></td>
          <td>
            <% if (r.plant_id) { %>
              <a href="/plant/<%= r.plant_code %>"><%= r.plant_name %></a>
              <span class="conf conf-<%= (r.match_confidence || 0) >= 0.7 ? 'high' : 'low' %>">
                <%= Math.round((r.match_confidence || 0) * 100) %>%
              </span>
            <% } else { %>
              <span class="muted">unmatched</span>
            <% } %>
          </td>
          <td><%= r.classification || '' %></td>
          <td><%= (r.reason || '').slice(0, 120) %></td>
        </tr>
      <% } %>
    </tbody>
  </table>
<% } %>

<%- include('_footer') %>
